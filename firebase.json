{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "server.py",
      "requirements.txt",
      "start.bat",
      "*.bat",
      "*.py",
      "*.sh",
      "*.db",
      "*.docx",
      "gen_report.js",
      "openspec/**",
      "db/**",
      ".github/**",
      ".claude/**"
    ],
    "rewrites": [
      { "source": "/main", "destination": "/main.html" },
      { "source": "/app",  "destination": "/app.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
